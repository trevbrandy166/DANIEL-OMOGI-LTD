<section class="page-header">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Let's discuss your business needs and deliver tailored solutions</p>
    </div>
</section>

<section class="content">
    <div class="container">
        <div class="contact-grid">
            <!-- Contact Info -->
            <div class="contact-info">
                <h2>Get In Touch</h2>
                <p>We welcome inquiries and consultations. Reach out to us through any of the channels below.</p>
                
                <div class="info-item">
                    <span class="info-icon">📍</span>
                    <div>
                        <h4>Physical Address</h4>
                        <p>P.O. Box 5280-00200, City Square<br>Nairobi, Kenya</p>
                    </div>
                </div>
                
                <div class="info-item">
                    <span class="info-icon">📞</span>
                    <div>
                        <h4>Telephone</h4>
                        <p><a href="tel:+254715475134">+254 715 475 134</a></p>
                        <p><a href="tel:+254705916757">+254 705 916 757</a></p>
                    </div>
                </div>
                
                <div class="info-item">
                    <span class="info-icon">✉️</span>
                    <div>
                        <h4>Email</h4>
                        <p><a href="mailto:info@danielomogi-associates.co.ke">info@danielomogi-associates.co.ke</a></p>
                    </div>
                </div>
                
                <div class="info-item">
                    <span class="info-icon">🌍</span>
                    <div>
                        <h4>Service Area</h4>
                        <p>Professional services across Kenya and beyond</p>
                    </div>
                </div>
                
                <div class="contact-actions">
                    <a href="https://wa.me/254715475134" class="btn btn-whatsapp" target="_blank">
                        💬 WhatsApp Us
                    </a>
                    <a href="tel:+254715475134" class="btn btn-call">
                        📞 Call Now
                    </a>
                </div>
            </div>
            
            <!-- Contact Form -->
            <div class="contact-form-wrapper">
                <% if (success) { %>
                    <div class="success-message">
                        <h3>✅ Thank You!</h3>
                        <p>Your message has been sent successfully. We'll get back to you within 24 hours.</p>
                        <a href="/" class="btn btn-primary">Back to Home</a>
                    </div>
                <% } else { %>
                    <h2>Send Us a Message</h2>
                    
                    <% if (errors && errors.length > 0) { %>
                        <div class="error-box">
                            <% errors.forEach(error => { %>
                                <p>⚠️ <%= error.msg %></p>
                            <% }) %>
                        </div>
                    <% } %>
                    
                    <form action="/contact" method="POST" class="contact-form">
                        <div class="form-group">
                            <label for="name">Full Name *</label>
                            <input type="text" id="name" name="name" value="<%= formData.name || '' %>" required>
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" name="phone" value="<%= formData.phone || '' %>">
                            </div>
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="company">Company Name</label>
                                <input type="text" id="company" name="company" value="<%= formData.company || '' %>">
                            </div>
                            <div class="form-group">
                                <label for="service">Service Interested In</label>
                                <select id="service" name="service">
                                    <option value="">Select a service</option>
                                    <option value="Audit & Assurance" <%= formData.service === 'Audit & Assurance' ? 'selected' : '' %>>Audit & Assurance</option>
                                    <option value="Tax Advisory" <%= formData.service === 'Tax Advisory' ? 'selected' : '' %>>Tax Advisory</option>
                                    <option value="HR Outsourcing" <%= formData.service === 'HR Outsourcing' ? 'selected' : '' %>>HR Outsourcing</option>
                                    <option value="Risk Advisory" <%= formData.service === 'Risk Advisory' ? 'selected' : '' %>>Risk Advisory</option>
                                    <option value="ISO Consultancy" <%= formData.service === 'ISO Consultancy' ? 'selected' : '' %>>ISO Consultancy</option>
                                    <option value="Financial Planning" <%= formData.service === 'Financial Planning' ? 'selected' : '' %>>Financial Planning</option>
                                    <option value="Investment Advisory" <%= formData.service === 'Investment Advisory' ? 'selected' : '' %>>Investment Advisory</option>
                                    <option value="Retirement Planning" <%= formData.service === 'Retirement Planning' ? 'selected' : '' %>>Retirement Planning</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="message">Your Message *</label>
                            <textarea id="message" name="message" rows="5" required><%= formData.message || '' %></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-full">Send Message</button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</section>